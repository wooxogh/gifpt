# Copy to .env.audit and fill in real values.
# This file is sourced by run_weekly.sh — never commit .env.audit itself.

GIFPT_MYSQL_HOST=127.0.0.1
GIFPT_MYSQL_PORT=3306
GIFPT_MYSQL_USER=root
GIFPT_MYSQL_PASSWORD=your_local_mysql_password
GIFPT_MYSQL_DB=gifpt

OPENAI_API_KEY=sk-...

# Python interpreter (absolute path). Detect with: which python3
PYTHON=/Library/Frameworks/Python.framework/Versions/3.13/bin/python3
